{
  "name": "github-action",
  "version": "3.0.0-dev",
  "description": "GitHub Action for handling CLA / DCO signatures via PR comments. Maintained fork of contributor-assistant/github-action.",
  "scripts": {
    "build": "tsc --noEmit && esbuild src/main.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist/index.js",
    "test": "jest",
    "validate-actions": "action-validator action.yml .github/workflows/*.yml .github/workflows/*.yaml"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/badideasforsale/cla-github-action.git"
  },
  "keywords": [
    "actions",
    "cla",
    "dco",
    "contributor-license-agreement"
  ],
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.21",
    "esbuild": "^0.28.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3"
  },
  "author": "ibakshay; maintained by badideasforsale",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/badideasforsale/cla-github-action/issues"
  },
  "homepage": "https://github.com/badideasforsale/cla-github-action#readme"
}
